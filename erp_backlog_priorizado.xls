<?xml version="1.0"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
 xmlns:o="urn:schemas-microsoft-com:office:office"
 xmlns:x="urn:schemas-microsoft-com:office:excel"
 xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">
 <Styles>
  <Style ss:ID="Header">
   <Font ss:Bold="1"/>
   <Interior ss:Color="#D9E1F2" ss:Pattern="Solid"/>
  </Style>
 </Styles>
 <Worksheet ss:Name="Backlog ERP">
  <Table>
   <Row>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Prioridad</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Modulo</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Iniciativa</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Descripcion</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Impacto</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Esfuerzo</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Sprint sugerido</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">KPI objetivo</Data></Cell>
    <Cell ss:StyleID="Header"><Data ss:Type="String">Dependencias</Data></Cell>
   </Row>

   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Inventario</Data></Cell><Cell><Data ss:Type="String">Kardex transaccional</Data></Cell><Cell><Data ss:Type="String">Registrar entradas, salidas y ajustes como movimientos inmutables.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S1-S2</Data></Cell><Cell><Data ss:Type="String">Exactitud stock mayor a 99%</Data></Cell><Cell><Data ss:Type="String">Producto, bodega, usuario</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Ventas</Data></Cell><Cell><Data ss:Type="String">Flujo documento a documento</Data></Cell><Cell><Data ss:Type="String">Cotizacion a pedido a factura a cobro con trazabilidad.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">S1-S3</Data></Cell><Cell><Data ss:Type="String">Tiempo ciclo venta menos 30%</Data></Cell><Cell><Data ss:Type="String">Clientes, productos, impuestos</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Seguridad</Data></Cell><Cell><Data ss:Type="String">Permisos por accion</Data></Cell><Cell><Data ss:Type="String">Permisos ver crear aprobar anular por modulo y rol.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S1-S2</Data></Cell><Cell><Data ss:Type="String">0 incidentes por acceso indebido</Data></Cell><Cell><Data ss:Type="String">Roles, usuarios</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Auditoria</Data></Cell><Cell><Data ss:Type="String">Bitacora de cambios</Data></Cell><Cell><Data ss:Type="String">Guardar quien, cuando y que cambio en entidades criticas.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S2</Data></Cell><Cell><Data ss:Type="String">100% operaciones criticas auditadas</Data></Cell><Cell><Data ss:Type="String">Infra logging</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Datos maestros</Data></Cell><Cell><Data ss:Type="String">Gobierno de catalogos</Data></Cell><Cell><Data ss:Type="String">Normalizar tipos de producto, impuestos, listas de precio, unidades.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S1-S2</Data></Cell><Cell><Data ss:Type="String">Menos errores de carga en 40%</Data></Cell><Cell><Data ss:Type="String">UI catalogos</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P1</Data></Cell><Cell><Data ss:Type="String">Facturacion</Data></Cell><Cell><Data ss:Type="String">Estados de comprobante</Data></Cell><Cell><Data ss:Type="String">Borrador aprobado anulado con reglas por estado.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S2-S3</Data></Cell><Cell><Data ss:Type="String">0 ediciones ilegales post aprobacion</Data></Cell><Cell><Data ss:Type="String">Permisos por accion</Data></Cell></Row>

   <Row><Cell><Data ss:Type="String">P2</Data></Cell><Cell><Data ss:Type="String">Compras</Data></Cell><Cell><Data ss:Type="String">Orden de compra completa</Data></Cell><Cell><Data ss:Type="String">Solicitud a orden a recepcion a cuenta por pagar.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">S3-S5</Data></Cell><Cell><Data ss:Type="String">Tiempo recepcion menos 20%</Data></Cell><Cell><Data ss:Type="String">Proveedores, inventario</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P2</Data></Cell><Cell><Data ss:Type="String">Contabilidad</Data></Cell><Cell><Data ss:Type="String">Asientos automaticos</Data></Cell><Cell><Data ss:Type="String">Generar asientos por ventas compras cobros pagos.</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">S4-S6</Data></Cell><Cell><Data ss:Type="String">Conciliacion mensual en menos tiempo 50%</Data></Cell><Cell><Data ss:Type="String">Plan de cuentas</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P2</Data></Cell><Cell><Data ss:Type="String">Caja y bancos</Data></Cell><Cell><Data ss:Type="String">Conciliacion bancaria</Data></Cell><Cell><Data ss:Type="String">Conciliar movimientos ERP con extractos bancarios.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S5</Data></Cell><Cell><Data ss:Type="String">Diferencias no conciliadas menor a 1%</Data></Cell><Cell><Data ss:Type="String">Asientos automaticos</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P2</Data></Cell><Cell><Data ss:Type="String">BI</Data></Cell><Cell><Data ss:Type="String">Dashboards ejecutivos</Data></Cell><Cell><Data ss:Type="String">Margen, rotacion, cartera, top clientes y top productos.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S4-S5</Data></Cell><Cell><Data ss:Type="String">Uso semanal por gerencia mayor a 80%</Data></Cell><Cell><Data ss:Type="String">Data mart basico</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P2</Data></Cell><Cell><Data ss:Type="String">Operaciones</Data></Cell><Cell><Data ss:Type="String">Alertas automatizadas</Data></Cell><Cell><Data ss:Type="String">Stock minimo, vencimientos, cuentas por cobrar.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Bajo</Data></Cell><Cell><Data ss:Type="String">S4</Data></Cell><Cell><Data ss:Type="String">Quiebres de stock menos 25%</Data></Cell><Cell><Data ss:Type="String">Kardex, compras, ventas</Data></Cell></Row>

   <Row><Cell><Data ss:Type="String">P3</Data></Cell><Cell><Data ss:Type="String">Arquitectura</Data></Cell><Cell><Data ss:Type="String">Eventos de dominio</Data></Cell><Cell><Data ss:Type="String">Publicar eventos internos para desacoplar modulos.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S6-S7</Data></Cell><Cell><Data ss:Type="String">Menor acoplamiento entre modulos</Data></Cell><Cell><Data ss:Type="String">Refactor servicios</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P3</Data></Cell><Cell><Data ss:Type="String">Integraciones</Data></Cell><Cell><Data ss:Type="String">APIs externas</Data></Cell><Cell><Data ss:Type="String">Conectar ERP con ecommerce y bancos.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Alto</Data></Cell><Cell><Data ss:Type="String">S7-S9</Data></Cell><Cell><Data ss:Type="String">Nuevos canales de venta activos</Data></Cell><Cell><Data ss:Type="String">Eventos de dominio</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P3</Data></Cell><Cell><Data ss:Type="String">Calidad</Data></Cell><Cell><Data ss:Type="String">Suite E2E critica</Data></Cell><Cell><Data ss:Type="String">Automatizar escenarios punta a punta de venta y compra.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S6-S8</Data></Cell><Cell><Data ss:Type="String">Regresiones en produccion menos 50%</Data></Cell><Cell><Data ss:Type="String">Ambiente QA estable</Data></Cell></Row>
   <Row><Cell><Data ss:Type="String">P3</Data></Cell><Cell><Data ss:Type="String">Rendimiento</Data></Cell><Cell><Data ss:Type="String">Optimizacion avanzada</Data></Cell><Cell><Data ss:Type="String">Caching selectivo, tuning de consultas, archivado historico.</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">Medio</Data></Cell><Cell><Data ss:Type="String">S8-S10</Data></Cell><Cell><Data ss:Type="String">Tiempo respuesta p95 menor a 500ms</Data></Cell><Cell><Data ss:Type="String">Monitoreo APM</Data></Cell></Row>
  </Table>
 </Worksheet>
</Workbook>
