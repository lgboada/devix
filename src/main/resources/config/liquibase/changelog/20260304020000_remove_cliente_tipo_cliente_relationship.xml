<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260304020000-1" author="devix">
        <addColumn tableName="cliente">
            <column name="tipo_cliente" type="varchar(255)"/>
        </addColumn>

        <sql>
            UPDATE cliente c
            SET tipo_cliente = tc.descripcion
            FROM tipo_cliente tc
            WHERE c.tipo_cliente_id = tc.id
              AND c.tipo_cliente IS NULL;
        </sql>

        <update tableName="cliente">
            <column name="tipo_cliente" value="SIN_DEFINIR"/>
            <where>tipo_cliente IS NULL OR trim(tipo_cliente) = ''</where>
        </update>

        <addNotNullConstraint tableName="cliente" columnName="tipo_cliente" columnDataType="varchar(255)"/>

        <dropForeignKeyConstraint baseTableName="cliente" constraintName="fk_cliente__tipo_cliente_id"/>
        <dropColumn tableName="cliente" columnName="tipo_cliente_id"/>
    </changeSet>
</databaseChangeLog>
