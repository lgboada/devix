<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260429110000-1" author="devix">
        <createTable tableName="paciente">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="no_cia" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="dni" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_dni" type="varchar(1)">
                <constraints nullable="true"/>
            </column>
            <column name="nombres" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="apellidos" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="titulo" type="varchar(250)">
                <constraints nullable="true"/>
            </column>
            <column name="fecha_nacimiento" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="sexo" type="varchar(2)">
                <constraints nullable="true"/>
            </column>
            <column name="orientacion_genero" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="identidad_sexual" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="grupo_sanguineo" type="varchar(5)">
                <constraints nullable="true"/>
            </column>
            <column name="estado_civil" type="varchar(1)">
                <constraints nullable="true"/>
            </column>
            <column name="nivel_estudio" type="varchar(250)">
                <constraints nullable="true"/>
            </column>
            <column name="ocupacion" type="varchar(120)">
                <constraints nullable="true"/>
            </column>
            <column name="religion" type="varchar(80)">
                <constraints nullable="true"/>
            </column>
            <column name="tipo_discapacidad" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="porcentaje_discapacidad" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="lateralidad" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="foto" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="numero_historia" type="varchar(15)">
                <constraints nullable="true"/>
            </column>
            <column name="tipo_historia" type="varchar(30)">
                <constraints nullable="true"/>
            </column>
            <column name="prioritario" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="comentario" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="actividades" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="agencia" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="area" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="ciiu" type="varchar(45)">
                <constraints nullable="true"/>
            </column>
            <column name="fecha_ingreso" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="fecha_egreso" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="motivo_salida" type="varchar(30)">
                <constraints nullable="true"/>
            </column>
            <column name="activo" type="boolean">
                <constraints nullable="true"/>
            </column>
            <column name="estado" type="varchar(3)">
                <constraints nullable="true"/>
            </column>
            <column name="fecha_creacion" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="ciudad_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="categoria_paciente_id" type="bigint">
                <constraints nullable="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260429110000-2" author="devix">
        <addForeignKeyConstraint
            baseColumnNames="ciudad_id"
            baseTableName="paciente"
            constraintName="fk_paciente_ciudad_id"
            referencedColumnNames="id"
            referencedTableName="ciudad"/>
    </changeSet>

    <changeSet id="20260429110000-3" author="devix">
        <addForeignKeyConstraint
            baseColumnNames="categoria_paciente_id"
            baseTableName="paciente"
            constraintName="fk_paciente_categoria_paciente_id"
            referencedColumnNames="id"
            referencedTableName="categoria_paciente"/>
    </changeSet>

</databaseChangeLog>
