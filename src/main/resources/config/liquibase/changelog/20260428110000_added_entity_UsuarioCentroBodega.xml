<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20260428110000-1" author="devix">
        <createTable tableName="usuario_centro_bodega">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="no_cia" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="principal" type="boolean">
                <constraints nullable="false"/>
            </column>
            <column name="centro_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="user_id" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="bodega_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260428110000-2" author="devix">
        <addUniqueConstraint
            tableName="usuario_centro_bodega"
            columnNames="user_id, bodega_id"
            constraintName="ux_ucb__user_id__bodega_id"/>
    </changeSet>

    <changeSet id="20260428110000-3" author="devix">
        <addForeignKeyConstraint
            baseTableName="usuario_centro_bodega"
            baseColumnNames="centro_id"
            constraintName="fk_ucb__centro_id"
            referencedTableName="centro"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="usuario_centro_bodega"
            baseColumnNames="user_id"
            constraintName="fk_ucb__user_id"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>

        <addForeignKeyConstraint
            baseTableName="usuario_centro_bodega"
            baseColumnNames="bodega_id"
            constraintName="fk_ucb__bodega_id"
            referencedTableName="bodega"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
