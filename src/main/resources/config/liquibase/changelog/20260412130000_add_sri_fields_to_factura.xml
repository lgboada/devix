<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260412130000-1" author="devix">
        <addColumn tableName="factura">
            <column name="clave_acceso" type="varchar(49)">
                <constraints nullable="true"/>
            </column>
            <column name="numero_autorizacion" type="varchar(37)">
                <constraints nullable="true"/>
            </column>
            <column name="fecha_autorizacion" type="${datetimeType}">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
